{
  "manifest_version": "0.4",
  "name": "github-mcp",
  "display_name": "Self-hosted GitHub MCP server",
  "version": "0.1.0",
  "description": "Self-hosted GitHub MCP server. PAT auth, stdio transport, transport-agnostic so it works with Claude Code (any account), Codex CLI, Cursor, or any MCP-compliant client.",
  "author": {
    "name": "adelaidasofia",
    "url": "https://github.com/adelaidasofia"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/adelaidasofia/github-mcp.git"
  },
  "homepage": "https://github.com/adelaidasofia/github-mcp",
  "documentation": "https://github.com/adelaidasofia/github-mcp#readme",
  "support": "https://github.com/adelaidasofia/github-mcp/issues",
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "fastmcp",
    "github"
  ],
  "server": {
    "type": "python",
    "entry_point": "server.py",
    "mcp_config": {
      "command": "python3",
      "args": [
        "${__dirname}/server.py"
      ],
      "env": {
        "GITHUB_TOKEN": "${user_config.github_token}"
      }
    }
  },
  "tools_generated": true,
  "compatibility": {
    "claude_desktop": ">=0.10.0",
    "platforms": [
      "darwin",
      "win32",
      "linux"
    ]
  },
  "user_config": {
    "github_token": {
      "type": "string",
      "title": "GitHub personal access token",
      "description": "Classic or fine-grained PAT with repo + workflow scopes",
      "required": true,
      "sensitive": true
    }
  }
}
